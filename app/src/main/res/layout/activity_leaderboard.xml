<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 Leaderboard"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#777777"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvTopStudent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Top Student: -"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#534AB7"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Add Reading Log -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etStudentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Student Name"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etPagesRead"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:hint="Pages"
            android:inputType="number"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnAddLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add"
            android:backgroundTint="#1D9E75"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>